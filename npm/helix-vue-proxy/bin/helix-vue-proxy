#!/usr/bin/env node

const { platform, arch, env } = process;
const { spawnSync } = require("child_process");

const PLATFORMS = {
  darwin: {
    x64: "@helix-vue-proxy/cli-darwin-x64/helix-vue-proxy",
    arm64: "@helix-vue-proxy/cli-darwin-arm64/helix-vue-proxy",
  },
  linux: {
    x64: "@helix-vue-proxy/cli-linux-x64-gnu/helix-vue-proxy",
  },
};

const binPath = env.HELIX_VUE_PROXY_BINARY || PLATFORMS?.[platform]?.[arch];

if (!binPath) {
  console.error(
    `helix-vue-proxy: no prebuilt binary for ${platform}/${arch}\n` +
      "Build from source: https://github.com/ushironoko/helix-vue-proxy#build-from-source",
  );
  process.exitCode = 1;
} else {
  let resolved;
  if (env.HELIX_VUE_PROXY_BINARY) {
    resolved = binPath;
  } else {
    try {
      resolved = require.resolve(binPath);
    } catch {
      console.error(
        `helix-vue-proxy: failed to find binary package for ${platform}/${arch}\n` +
          "The platform-specific package may not have been installed.\n" +
          "Try reinstalling: npm install -g helix-vue-proxy\n" +
          "Or build from source: https://github.com/ushironoko/helix-vue-proxy#build-from-source",
      );
      process.exitCode = 1;
      return;
    }
  }

  const result = spawnSync(resolved, process.argv.slice(2), {
    shell: false,
    stdio: "inherit",
  });

  if (result.error) throw result.error;

  if (result.signal) {
    process.kill(process.pid, result.signal);
  } else {
    process.exitCode = result.status;
  }
}
